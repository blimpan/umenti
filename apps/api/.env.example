# NOTE: actually used file needs to be named ".env" and not ".env.local". The latter is a Next.js convention.

# For connecting to Supabase via connection pooling
DATABASE_URL=
# For direct connection to the database. Used for migrations
DIRECT_URL=
SUPABASE_PROJECT_URL=
SUPABASE_SECRET_KEY=
PORT=3001

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

LLM_PROVIDER=
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Set to 'minutes' during development to observe score decay quickly.
# Leave unset (defaults to 'weeks') in production.
SCORE_DECAY_UNIT=