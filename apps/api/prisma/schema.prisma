generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  TEACHER
  STUDENT
}

enum CourseStatus {
  GENERATING
  FAILED
  DRAFT
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum ReviewStatus {
  UNREVIEWED
  IN_REVIEW
  APPROVED
  REJECTED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum ExerciseType {
  MULTIPLE_CHOICE
  FREE_TEXT
  INTERACTIVE
}

enum MaterialType {
  FILE
  LINK
}

enum ExerciseSource {
  TEACHER_PROVIDED
  AI_PROVIDED
}

enum AttemptPhase {
  PRIOR_KNOWLEDGE
  MAIN
}

enum MessageRole {
  AI
  STUDENT
  SYSTEM
}

enum MessageType {
  TEXT
  THEORY_BLOCK
  EXERCISE_CARD
  PRIOR_KNOWLEDGE_QUESTION
  SYSTEM_MESSAGE
  CONCEPT_MASTERY_REACHED
  MODULE_END_REACHED
}

model User {
  supabaseId     String          @id
  email          String          @unique
  role           Role
  createdAt      DateTime        @default(now())

  teacherProfile TeacherProfile?
  studentProfile StudentProfile?
}

model TeacherProfile {
  userId  String  @id
  user    User    @relation(fields: [userId], references: [supabaseId], onDelete: Cascade)

  courses Course[]
}

model StudentProfile {
  userId  String  @id
  user    User    @relation(fields: [userId], references: [supabaseId], onDelete: Cascade)

  enrollments     Enrollment[]
  conceptProgress StudentConceptProgress[]
  moduleSessions  ModuleSession[]
}

model Course {
  id             Int            @id @default(autoincrement())
  teacher        TeacherProfile @relation(fields: [teacherId], references: [userId])
  teacherId      String
  name           String
  subject        String
  language       String
  targetAudience String
  status         CourseStatus   @default(GENERATING)
  createdAt      DateTime       @default(now())

  courseModules CourseModule[]
  concepts      Concept[]
  materials     CourseMaterial[]
  enrollments      Enrollment[]
  exerciseAnalyses ExerciseAnalysis[]
}

model Enrollment {
  id        Int              @id @default(autoincrement())
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  Int
  email     String
  student   StudentProfile?  @relation(fields: [userId], references: [userId])
  userId    String?
  status    EnrollmentStatus @default(PENDING)
  createdAt DateTime         @default(now())

  @@unique([courseId, email])
  @@index([userId])
  @@index([email])
}

model CourseModule {
  id            Int          @id @default(autoincrement())
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId      Int
  name          String
  order         Int
  whyThisModule String?
  buildsOn      String?
  leadsInto     String?
  reviewStatus  ReviewStatus @default(UNREVIEWED)

  objectives    LearningObjective[]
  outcomes      LearningOutcome[]
  exercises     Exercise[]
  conceptLinks  ModuleConcept[]
  materialLinks CourseMaterialModule[]
  sessions      ModuleSession[]

  @@index([courseId])
}

model LearningObjective {
  id             Int          @id @default(autoincrement())
  courseModule   CourseModule @relation(fields: [courseModuleId], references: [id], onDelete: Cascade)
  courseModuleId Int
  text           String

  outcomeLinks OutcomeObjective[]

  @@index([courseModuleId])
}

model LearningOutcome {
  id             Int          @id @default(autoincrement())
  courseModule   CourseModule @relation(fields: [courseModuleId], references: [id], onDelete: Cascade)
  courseModuleId Int
  text           String

  objectiveLinks OutcomeObjective[]
  conceptLinks   ConceptOutcome[]

  @@index([courseModuleId])
}

model OutcomeObjective {
  outcome     LearningOutcome   @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  outcomeId   Int
  objective   LearningObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  objectiveId Int

  @@id([outcomeId, objectiveId])
}

model Concept {
  id            Int     @id @default(autoincrement())
  course        Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId      Int
  name          String
  visualization String?    // optional LLM-generated HTML; one per concept
  conceptType   String?

  outcomeLinks    ConceptOutcome[]
  moduleLinks     ModuleConcept[]
  theoryBlocks    TheoryBlock[]
  exerciseLinks   ExerciseConcept[]
  progressEntries StudentConceptProgress[]
  visualizations  ConceptVisualization[]

  @@index([courseId])
}

model ConceptOutcome {
  concept   Concept         @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId Int
  outcome   LearningOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  outcomeId Int

  @@id([conceptId, outcomeId])
}

model ModuleConcept {
  module    CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  Int
  concept   Concept      @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId Int
  order     Int

  @@id([moduleId, conceptId])
}

model TheoryBlock {
  id              Int     @id @default(autoincrement())
  concept         Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId       Int
  content         String
  order           Int
  pendingRevision Boolean @default(false)

  @@index([conceptId])
}

model ConceptVisualization {
  id                  Int     @id @default(autoincrement())
  concept             Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId           Int
  order               Int
  visualizationType   String
  visualizationParams Json
  visualization       String? // custom HTML fallback when templateId = 'custom'

  @@index([conceptId])
}

model Exercise {
  id                  Int          @id @default(autoincrement())
  courseModule        CourseModule @relation(fields: [courseModuleId], references: [id], onDelete: Cascade)
  courseModuleId      Int
  type                ExerciseType
  question            String
  order               Int
  pendingRevision     Boolean      @default(false)
  options             Json?
  correctIndex        Int?
  explanation         String?
  sampleAnswer        String?
  rubric              String?
  canonicalExpressions Json?       // Array<{ label: string, sympyExpr: string | null }>
  visualizationHtml   String?      // used when type = INTERACTIVE
  targetState         Json?        // server-only; never sent to client
  visualizationType   String?
  visualizationParams Json?

  source       ExerciseSource    @default(TEACHER_PROVIDED)
  conceptLinks ExerciseConcept[]
  analysis     ExerciseAnalysis?

  @@index([courseModuleId])
}

model ExerciseConcept {
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId Int
  concept    Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId  Int

  @@id([exerciseId, conceptId])
}

model StudentConceptProgress {
  student        StudentProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  userId         String
  concept        Concept        @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId      Int
  score          Float
  lastActivityAt DateTime       @updatedAt

  @@id([userId, conceptId])
}

model CourseMaterial {
  id         Int          @id @default(autoincrement())
  course     Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId   Int
  type       MaterialType
  filename   String?
  storageKey String?
  title      String?
  url        String?

  moduleLinks CourseMaterialModule[]
}

model CourseMaterialModule {
  material   CourseMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialId Int
  module     CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId   Int

  @@id([materialId, moduleId])
}

model ModuleSession {
  id        String         @id @default(uuid())
  userId    String
  student   StudentProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  moduleId  Int
  module    CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  messages  ChatMessage[]

  @@unique([userId, moduleId])
}

model ExerciseAttempt {
  id          Int          @id @default(autoincrement())
  userId      String
  exerciseId  Int
  sessionId   String
  conceptId   Int
  moduleId    Int
  courseId    Int
  phase       AttemptPhase
  isCorrect   Boolean
  scoreChange Float
  answer      String?
  createdAt   DateTime     @default(now())

  @@index([userId, courseId])
  @@index([courseId, conceptId])
  @@index([courseId, createdAt])
}

model ChatMessage {
  id        String        @id @default(uuid())
  sessionId String
  session   ModuleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  type      MessageType
  payload   Json
  order     Int
  createdAt DateTime      @default(now())

  @@index([sessionId])
}

model CurriculumTemplate {
  id             Int                      @id @default(autoincrement())
  country        String
  subject        String
  grade          String
  name           String
  language       String
  targetAudience String
  modules        CurriculumTemplateModule[]

  @@index([country, subject])
}

model CurriculumTemplateModule {
  id         Int                    @id @default(autoincrement())
  templateId Int
  template   CurriculumTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  order      Int
  objectives TemplateObjective[]
  outcomes   TemplateOutcome[]

  @@index([templateId])
}

model TemplateObjective {
  id       Int                      @id @default(autoincrement())
  moduleId Int
  module   CurriculumTemplateModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  text     String

  @@index([moduleId])
}

model TemplateOutcome {
  id       Int                      @id @default(autoincrement())
  moduleId Int
  module   CurriculumTemplateModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  text     String

  @@index([moduleId])
}

model ExerciseAnalysis {
  id                       Int      @id @default(autoincrement())
  exerciseId               Int      @unique
  courseId                 Int
  summary                  String
  commonMisconceptions     Json     // string[]
  attemptCountAtGeneration Int
  generatedAt              DateTime @default(now())

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}
